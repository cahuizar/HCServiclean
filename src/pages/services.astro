---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/services/ServiceCard.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import PageHeader from '../components/shared/PageHeader.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="House Cleaning Services in Indiana | HC ServiClean"
  description="Professional residential cleaning services including bedrooms, bathrooms, kitchens, and special extras in Fishers, Carmel, Noblesville, and Indianapolis, Indiana. Service quote-based — no time limits."
  canonical="https://hcserviclean.com/services/"
>
  <PageHeader
    title="Professional House Cleaning Services in Indiana"
    subtitle="Every clean is guaranteed to your satisfaction. We stay until the job is done — we quote by service, not by time."
    breadcrumb="Services"
  />

  <!-- Services grid -->
  <section class="bg-slate-50 py-20" aria-labelledby="services-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        id="services-heading"
        title="What We Offer That Others Don't"
        subtitle="Professional, thorough, and consistent — your home cleaned the way you want it."
      />

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <!-- Service promise -->
  <section class="bg-white py-16" aria-labelledby="promise-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 id="promise-heading" class="text-3xl font-bold text-slate-900">Our Service Promise</h2>
        <div class="mt-4 h-1 w-16 rounded-full bg-gold mx-auto"></div>
        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {[
            {
              title: 'Service Quote, Not Time Quote',
              body: 'We stay until the job is done right — not by the clock.',
            },
            {
              title: 'Your Supplies or Ours',
              body: 'We bring everything needed, or use your preferred products.',
            },
            {
              title: 'No Need to Be Home',
              body: 'As long as we have entry instructions, you can relax elsewhere.',
            },
          ].map(({ title, body }) => (
            <div class="rounded-xl bg-white p-6 shadow-sm text-left">
              <div class="mb-3 h-1 w-8 rounded-full bg-teal"></div>
              <h3 class="font-bold text-slate-900">{title}</h3>
              <p class="mt-2 text-sm text-slate-600">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-50 py-16 text-center" aria-label="Get started">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">Ready to Book a Clean?</h2>
      <p class="mt-2 text-slate-600">Get your free estimate — no obligation, no pressure.</p>
      <div class="mt-6">
        <a href="/estimate/" class="btn-primary text-base px-10 py-3.5">
          Get a Free Estimate
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
