---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqItem from '../components/faq/FaqItem.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import PageHeader from '../components/shared/PageHeader.astro';
import { faqs } from '../data/faqs';

const generalFaqs = faqs.filter((f) => f.category === 'general');
const trustFaqs = faqs.filter((f) => f.category === 'trust');

// FAQPage schema for rich results in Google
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''), // strip HTML for schema
    },
  })),
};
---

<BaseLayout
  title="FAQ | House Cleaning in Fishers & Indianapolis, IN"
  description="Got questions about our house cleaning services? Answers to common questions about HC ServiClean's services, scheduling, pricing, and policies for Fishers, IN and surrounding areas."
  canonical="https://hcserviclean.com/faq/"
>
  <!-- FAQPage structured data (can live in body — Google parses it anywhere) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <PageHeader
    title="House Cleaning FAQ — Fishers & Indianapolis, IN"
    subtitle="Have a question? Check out the answers below. Still need help? Email us at info@hcserviclean.com"
    breadcrumb="FAQ"
  />

  <!-- FAQ content -->
  <section class="bg-slate-50 py-20" aria-labelledby="faq-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- General -->
        <div>
          <SectionHeader title="General Questions" />
          <div class="divide-y divide-slate-200 rounded-2xl border border-slate-100 bg-white px-6 shadow-sm">
            {generalFaqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
          </div>
        </div>

        <!-- Trust & Safety -->
        <div>
          <SectionHeader title="Trust &amp; Safety" />
          <div class="divide-y divide-slate-200 rounded-2xl border border-slate-100 bg-white px-6 shadow-sm">
            {trustFaqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
          </div>
        </div>
      </div>

      <!-- Still have questions? -->
      <div class="mt-16 rounded-2xl bg-slate-50 p-8 text-center">
        <h2 class="text-xl font-bold text-slate-900">Still have questions?</h2>
        <p class="mt-2 text-slate-600">We're happy to help. Reach out and we'll respond within one business day.</p>
        <div class="mt-6 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="mailto:info@hcserviclean.com?Subject=Question" class="btn-primary">
            Email Us
          </a>
          <a href="tel:+18472934525" class="btn-teal-outline">
            Call (847) 293-4525
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
