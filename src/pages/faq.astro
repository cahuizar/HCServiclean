---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqItem from '../components/faq/FaqItem.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import Newsletter from '../components/shared/Newsletter.astro';
import { faqs } from '../data/faqs';

const generalFaqs = faqs.filter((f) => f.category === 'general');
const trustFaqs = faqs.filter((f) => f.category === 'trust');

// FAQPage schema for rich results in Google
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''), // strip HTML for schema
    },
  })),
};
---

<BaseLayout
  title="Frequently Asked Questions | HC ServiClean House Cleaning"
  description="Got questions about our house cleaning services? Find answers to our most frequently asked questions about HC ServiClean's services, scheduling, pricing, and policies."
  canonical="https://hcserviclean.com/faq"
>
  <!-- FAQPage structured data (can live in body — Google parses it anywhere) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Page header -->
  <section class="bg-slate-900 py-20 pt-36" aria-label="Page header">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-sm text-slate-400" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li class="text-white font-bold" aria-current="page">FAQ</li>
        </ol>
      </nav>
      <h1 class="text-4xl font-bold text-white sm:text-5xl">Frequently Asked Questions</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-300">
        Have a question? Check out the answers below. Still need help?{' '}
        <a href="mailto:contact@hcserviclean.com" class="text-teal underline hover:text-teal-light">
          Email us anytime.
        </a>
      </p>
    </div>
  </section>

  <!-- FAQ content -->
  <section class="bg-white py-20" aria-labelledby="faq-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- General -->
        <div>
          <SectionHeader title="General Questions" />
          <div class="divide-y divide-slate-200 rounded-2xl border border-slate-100 bg-white px-6 shadow-sm">
            {generalFaqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
          </div>
        </div>

        <!-- Trust & Safety -->
        <div>
          <SectionHeader title="Trust &amp; Safety" />
          <div class="divide-y divide-slate-200 rounded-2xl border border-slate-100 bg-white px-6 shadow-sm">
            {trustFaqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
          </div>
        </div>
      </div>

      <!-- Still have questions? -->
      <div class="mt-16 rounded-2xl bg-teal-50 p-8 text-center">
        <h2 class="text-xl font-bold text-slate-900">Still have questions?</h2>
        <p class="mt-2 text-slate-600">We're happy to help. Reach out and we'll respond within one business day.</p>
        <div class="mt-6 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="mailto:contact@hcserviclean.com?Subject=Question" class="btn-primary">
            Email Us
          </a>
          <a href="tel:+18472934525" class="btn-teal-outline">
            Call (847) 293-4525
          </a>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>
