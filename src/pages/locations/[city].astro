---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/shared/PageHeader.astro';
import { locations } from '../../data/locations';
import { services } from '../../data/services';
import { faqs } from '../../data/faqs';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { city: loc.slug },
    props: loc,
  }));
}

const location = Astro.props;

// Pull top 2 general FAQs for the page FAQ section
const pageFaqs = faqs.filter((f) => f.category === 'general').slice(0, 2);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};

const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'CleaningService'],
  name: 'HC ServiClean LLC',
  description: `Professional residential house cleaning services in ${location.city}, ${location.state}. Background-checked, full-time employees. Free estimates.`,
  url: `https://hcserviclean.com${location.canonicalPath}`,
  telephone: '+1-847-293-4525',
  email: 'info@hcserviclean.com',
  areaServed: {
    '@type': 'City',
    name: location.city,
    containedInPlace: {
      '@type': 'State',
      name: 'Indiana',
    },
  },
  paymentAccepted: ['Cash', 'Check'],
  image: 'https://hcserviclean.com/images/og-image.jpg',
  sameAs: [
    'https://www.facebook.com/profile.php?id=61555496861439',
    'https://www.yelp.com/biz/hc-serviclean-noblesville-2',
  ],
  foundingDate: '2010',
};
---

<BaseLayout
  title={location.metaTitle}
  description={location.metaDescription}
  canonical={`https://hcserviclean.com${location.canonicalPath}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(cityBusinessSchema)} />

  <PageHeader
    title={location.headline}
    subtitle={`Trusted by ${location.city} families since 2010. Background-checked, full-time employees. 100% satisfaction guaranteed.`}
    breadcrumb={location.city}
    parentCrumb={{ label: 'Locations', href: '/locations/' }}
  />

  <!-- Intro + Trust signals -->
  <section class="bg-white py-16" aria-labelledby="intro-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <!-- Intro text -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-teal">
            Serving {location.county}
          </p>
          <h2 id="intro-heading" class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">
            Your Trusted Local Cleaning Team
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-slate-600">{location.intro}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/estimate/" class="btn-primary">Get a Free Estimate</a>
            <a href="/services/" class="btn-teal-outline">View All Services</a>
          </div>
        </div>

        <!-- Trust chips -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
          {[
            { icon: '✓', title: 'Background Checked', body: 'All staff thoroughly background & reference checked.' },
            { icon: '✓', title: 'Full-Time Employees', body: 'Not contractors — trained employees every time.' },
            { icon: '✓', title: 'Satisfaction Guaranteed', body: 'Not happy? We come back free, no questions asked.' },
          ].map(({ icon, title, body }) => (
            <div class="flex gap-4 rounded-2xl border border-slate-100 p-5 shadow-sm">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal text-slate-900 font-bold">
                {icon}
              </div>
              <div>
                <p class="font-bold text-slate-900">{title}</p>
                <p class="mt-0.5 text-sm text-slate-600">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services offered -->
  <section class="bg-slate-50 py-16" aria-labelledby="services-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-teal">What We Clean</p>
        <h2 id="services-heading" class="mt-2 text-3xl font-bold text-slate-900">
          Full-Service Home Cleaning in {location.city}
        </h2>
        <p class="mt-2 text-slate-500">
          Every room, done right — on your schedule.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => (
          <div class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
            <Image
              src={service.image}
              alt={service.imageAlt}
              width={400}
              height={260}
              class="h-44 w-full object-cover"
              loading="lazy"
            />
            <div class="p-5">
              <h3 class="font-bold text-slate-900">{service.title}</h3>
              <ul class="mt-3 space-y-1.5">
                {service.items.slice(0, 3).map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <span class="mt-0.5 h-4 w-4 shrink-0 rounded-full bg-teal/20 text-center text-xs font-bold leading-4 text-teal">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-8 text-center">
        <a href="/services/" class="btn-teal-outline">
          See Full Service Details
        </a>
      </p>
    </div>
  </section>

  <!-- Nearby areas / inter-city link mesh -->
  <section class="bg-white py-12" aria-labelledby="nearby-heading">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="nearby-heading" class="text-xl font-bold text-slate-900">
        Also Serving Nearby Communities
      </h2>
      <p class="mt-1 text-slate-500">
        We clean homes throughout central Indiana — {location.city} and beyond.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {location.nearbyAreas.map((area) => {
          const nearbyLoc = locations.find((l) => l.city === area);
          return nearbyLoc ? (
            <a
              href={nearbyLoc.canonicalPath}
              class="rounded-full border border-teal/30 bg-slate-50 px-4 py-1.5 text-sm font-medium text-slate-700 shadow-sm transition-colors hover:bg-teal/10 hover:border-teal"
            >
              {area}, IN
            </a>
          ) : (
            <span class="rounded-full border border-teal/30 bg-slate-50 px-4 py-1.5 text-sm font-medium text-slate-700 shadow-sm">
              {area}, IN
            </span>
          );
        })}
        <a
          href="/about/#areas-heading"
          class="rounded-full border border-slate-200 bg-white px-4 py-1.5 text-sm font-medium text-teal shadow-sm transition-colors hover:bg-teal/10"
        >
          View Full Service Area →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ excerpt -->
  <section class="bg-slate-50 py-16" aria-labelledby="faq-heading">
    <div class="container mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-teal">Common Questions</p>
        <h2 id="faq-heading" class="mt-2 text-2xl font-bold text-slate-900">
          Frequently Asked Questions
        </h2>
      </div>
      <div class="divide-y divide-slate-200 rounded-2xl border border-slate-100 bg-white px-6 shadow-sm">
        {pageFaqs.map((faq) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-slate-900 hover:text-teal">
              {faq.question}
              <span class="shrink-0 text-teal transition-transform group-open:rotate-45" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
                  <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600" set:html={faq.answer} />
          </details>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-slate-500">
        More questions?
        <a href="/faq/" class="font-semibold text-teal hover:text-teal-dark underline">
          Visit our full FAQ page
        </a>
      </p>
    </div>
  </section>

  <!-- CTA band -->
  <section
    class="relative py-24 text-center"
    style="background-image: url('/images/contact-parallax.jpg'); background-size: cover; background-position: center;"
    aria-label="Call to action"
  >
    <div class="absolute inset-0 bg-slate-900/70"></div>
    <div class="relative z-10 px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Ready for a Cleaner Home in {location.city}?
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-lg text-white/80">
        Request your free estimate today. We'll reach out within one business day.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/estimate/" class="btn-primary text-base px-10 py-3.5 w-full sm:w-auto">
          Get a Free Estimate
        </a>
        <a href="tel:+18472934525" class="btn-outline text-base px-10 py-3.5 w-full sm:w-auto">
          Call (847) 293-4525
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
