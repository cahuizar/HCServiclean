---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ServiceHighlights from '../components/home/ServiceHighlights.astro';
import Testimonials from '../components/home/Testimonials.astro';
import Newsletter from '../components/shared/Newsletter.astro';
---

<BaseLayout
  title="HC ServiClean | Fishers House Cleaning Services | Get a Free Estimate"
  description="We have provided the best house cleaning services in Fishers, Noblesville, Carmel, Geist, and Indianapolis for over 10 years. Trust us to get the cleaning done right. The solution to all your cleaning needs!"
  canonical="https://hcserviclean.com/"
>
  <Hero />

  <!-- Why Choose Us strip -->
  <section class="bg-slate-900 py-10" aria-label="Why choose us highlights">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center md:grid-cols-4">
        {[
          { number: '10+', label: 'Years of Excellence' },
          { number: '100%', label: 'Satisfaction Guaranteed' },
          { number: 'Free', label: 'Estimates Always' },
          { number: 'Trusted', label: 'Background Checked Staff' },
        ].map(({ number, label }) => (
          <div>
            <p class="text-2xl font-bold text-gold sm:text-3xl">{number}</p>
            <p class="mt-1 text-xs font-bold uppercase tracking-widest text-slate-400 sm:text-sm">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ServiceHighlights />

  <Testimonials />

  <!-- CTA banner -->
  <section
    class="relative py-24 text-center"
    style="background-image: url('/images/contact-parallax.jpg'); background-size: cover; background-position: center;"
    aria-label="Call to action"
  >
    <div class="absolute inset-0 bg-slate-900/70"></div>
    <div class="relative z-10 px-4">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready for a Cleaner Home?</h2>
      <p class="mx-auto mt-3 max-w-xl text-lg text-white/80">
        Request your free estimate today. We'll reach out within one business day.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/estimate" class="btn-primary text-base px-10 py-3.5 w-full sm:w-auto">
          Get a Free Estimate
        </a>
        <a href="tel:+18472934525" class="btn-outline text-base px-10 py-3.5 w-full sm:w-auto">
          Call (847) 293-4525
        </a>
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>
