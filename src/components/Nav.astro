---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo-no-slogan.png';
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/locations/', label: 'Locations' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/estimate/', label: 'Free Estimate' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  id="site-header"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href="/"
      aria-label="HC ServiClean — go to homepage"
      class="flex items-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white rounded"
    >
      <Image
        src={logo}
        alt="HC ServiClean LLC logo"
        width={76}
        height={64}
        class="nav-logo h-14 w-auto transition-all duration-300 sm:h-16"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-1 lg:flex" role="list">
      {
        navLinks.map((link) => {
          const isEstimate = link.href === '/estimate/';
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <li>
              {isEstimate ? (
                <a
                  href={link.href}
                  class="btn-primary ml-4 !py-2 !px-6 text-sm"
                >
                  {link.label}
                </a>
              ) : (
                <a
                  href={link.href}
                  class:list={[
                    'relative px-4 py-2 text-sm font-bold transition-colors duration-200 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white',
                    'nav-text-color',
                    isActive
                      ? 'after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-gold after:rounded-full'
                      : 'hover:text-gold',
                  ]}
                >
                  {link.label}
                </a>
              )}
            </li>
          );
        })
      }
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
      class="flex h-11 w-11 items-center justify-center rounded-full nav-text-color transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white lg:hidden"
    >
      <svg
        id="hamburger-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="h-6 w-6"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg
        id="close-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="hidden h-6 w-6"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t-2 border-teal bg-white shadow-2xl lg:hidden"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <!-- Nav links (Home / About / Services / FAQ) -->
    <ul class="flex flex-col px-4 pt-4 pb-2" role="list">
      {
        navLinks.filter((l) => l.href !== '/estimate').map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  'flex min-h-[44px] items-center rounded-xl px-4 py-3 text-base font-bold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal',
                  isActive
                    ? 'bg-teal/10 text-teal'
                    : 'text-slate-800 hover:bg-slate-50 hover:text-teal',
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Divider -->
    <div class="mx-4 border-t border-slate-100 my-1"></div>

    <!-- CTA + quick call -->
    <div class="flex flex-col gap-3 px-4 py-5">
      <a
        href="/estimate/"
        class="btn-primary flex w-full items-center justify-center text-base py-3.5"
      >
        Get a Free Estimate
      </a>
      <a
        href="tel:+18472934525"
        class="flex min-h-[44px] items-center justify-center gap-2 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 transition-colors hover:border-teal hover:text-teal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 shrink-0 text-teal" aria-hidden="true">
          <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/>
        </svg>
        (847) 293-4525
      </a>
    </div>
  </div>
</header>

<style>
  /* Default nav: transparent, white text (for hero pages) */
  #site-header {
    background-color: transparent;
  }
  .nav-text-color {
    color: white;
  }

  /* Logo icon: invert to white on dark/transparent nav */
  #site-header .nav-logo {
    filter: brightness(0) invert(1);
  }

  /* Scrolled state */
  #site-header.scrolled {
    background-color: white;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
  }
  #site-header.scrolled .nav-text-color {
    color: #1e293b;
  }
  #site-header.scrolled .nav-logo {
    filter: none;
  }
  #site-header.scrolled #mobile-menu-toggle:hover {
    background-color: #f1f5f9;
  }

  /* Solid nav on non-hero pages */
  #site-header.solid {
    background-color: white;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
  }
  #site-header.solid .nav-text-color {
    color: #1e293b;
  }
  #site-header.solid .nav-logo {
    filter: none;
  }

  /* Mobile menu open — force white nav so menu connects cleanly */
  #site-header.menu-open {
    background-color: white;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
  }
  #site-header.menu-open .nav-text-color {
    color: #1e293b;
  }
  #site-header.menu-open .nav-logo {
    filter: none;
  }
  #site-header.menu-open #mobile-menu-toggle:hover {
    background-color: #f1f5f9;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  // Solid nav on pages without a hero background
  const hasHero = document.querySelector('[data-hero]');
  if (!hasHero && header) {
    header.classList.add('solid');
  }

  // Scroll-based transparent ↔ white nav
  function updateNav() {
    if (!header || header.classList.contains('solid')) return;
    // Don't fight the menu-open override while menu is open
    if (header.classList.contains('menu-open')) return;
    if (window.scrollY > 60) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Shared helper — close menu and restore correct nav state
  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    // Remove forced-white override, then let scroll position decide
    header?.classList.remove('menu-open');
    updateNav();
  }

  // Mobile menu toggle
  toggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      closeMenu();
    } else {
      mobileMenu?.classList.remove('hidden');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      // Force white nav so the open menu connects cleanly to the header
      header?.classList.add('menu-open');
    }
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  // Close mobile menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });
</script>
