---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/carousel-1.jpg';
const yearsInBusiness = new Date().getFullYear() - 2010;
---

<section
  id="home"
  data-hero
  class="relative flex min-h-screen items-center justify-center overflow-hidden"
  aria-label="Hero"
>
  <!-- Background image — LCP element, fetchpriority high -->
  <Image
    src={heroBg}
    alt="Beautiful clean home interior"
    class="absolute inset-0 h-full w-full object-cover object-center"
    fetchpriority="high"
    decoding="sync"
    loading="eager"
  />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-slate-900/60"></div>

  <!-- Content -->
  <div class="relative z-10 px-4 text-center sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-sm font-bold text-white backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-gold animate-pulse"></span>
        Serving Indiana Since 2010
      </div>

      <!-- Headline -->
      <h1 class="text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
        HC <span class="text-teal">Servi</span><span class="text-gold">Clean</span>
      </h1>

      <p class="mt-4 text-xl font-bold text-white sm:text-2xl">
        Indiana's Trusted Residential Cleaning Service
      </p>

      <p class="mt-3 text-base text-white/80 sm:text-lg">
        Serving Fishers, Carmel, Noblesville, Geist, and the greater Indianapolis area
        for over <strong class="text-gold">{yearsInBusiness} years</strong>.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/estimate" class="btn-primary w-full sm:w-auto text-base px-10 py-3.5">
          Get a Free Estimate
        </a>
        <a href="/services" class="btn-outline w-full sm:w-auto text-base px-10 py-3.5">
          View Our Services
        </a>
      </div>

      <!-- Trust badges -->
      <div class="mt-10 flex flex-col items-center justify-center gap-6 sm:flex-row sm:gap-10">
        {[
          { icon: '✓', text: 'Background Checked' },
          { icon: '✓', text: 'Full-Time Employees' },
          { icon: '✓', text: 'Free Estimates' },
        ].map(({ icon, text }) => (
          <div class="flex items-center gap-2 text-sm font-bold text-white/90">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-teal text-slate-900 text-xs font-bold">{icon}</span>
            {text}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator — mouse icon + label, clicks to scroll to next section -->
  <button
    data-scroll-next
    aria-label="Scroll down to explore"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/50 transition-colors duration-200 hover:text-white/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white rounded"
  >
    <!-- Mouse outline with animated scroll dot -->
    <div class="flex h-9 w-5 items-start justify-center rounded-full border-2 border-current pt-1.5">
      <div class="h-2 w-px animate-bounce rounded-full bg-current"></div>
    </div>
    <span class="text-[9px] font-bold uppercase tracking-widest">Scroll</span>
  </button>
</section>

<script>
  document.querySelector('[data-scroll-next]')?.addEventListener('click', () => {
    document.querySelector('[data-hero]')
      ?.nextElementSibling
      ?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
