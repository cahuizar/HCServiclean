---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/carousel-1.jpg';
import BubbleDecor from '../shared/BubbleDecor.astro';
const yearsInBusiness = new Date().getFullYear() - 2010;

const trustChips = [
  { icon: '✓', text: 'Background Checked' },
  { icon: '✓', text: 'Full-Time Employees' },
  { icon: '✓', text: 'Free Estimates' },
];
---

<section
  id="home"
  data-hero
  class="relative overflow-hidden bg-slate-900"
  aria-label="Hero"
>
  <BubbleDecor variant="dark" />

  <!-- Two-column grid: copy left, photo right -->
  <div class="relative z-10 mx-auto grid min-h-screen max-w-7xl grid-cols-1 lg:grid-cols-2">

    <!-- ── LEFT: Copy panel ──────────────────────────────────────────────── -->
    <div class="flex flex-col justify-center px-6 py-36 sm:px-12 lg:px-16 lg:py-28">

      <!-- Badge -->
      <div class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-bold text-white backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-gold animate-pulse"></span>
        Serving Indiana Since 2010
      </div>

      <!-- H1 — brand name is the visual star; keyword phrase is part of the H1 for SEO -->
      <h1 class="leading-tight text-white">
        <span class="block text-5xl font-bold sm:text-6xl lg:text-7xl">
          HC <span class="text-teal">Servi</span><span class="text-gold">Clean</span>
        </span>
        <span class="mt-3 block text-lg font-medium tracking-wide text-white/70 sm:text-xl">
          House Cleaning — Fishers, Carmel &amp; Indianapolis, IN
        </span>
      </h1>

      <!-- Subtext -->
      <p class="mt-5 max-w-md text-base leading-relaxed text-white/55">
        Background-checked, full-time employees serving Indiana families for over
        <strong class="font-semibold text-white/80">{yearsInBusiness} years</strong>.
        We quote by service — not the clock.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/estimate/" class="btn-primary text-base px-8 py-3.5">
          Get a Free Estimate
        </a>
        <a href="/services/" class="btn-outline text-base px-8 py-3.5">
          View Our Services
        </a>
      </div>

      <!-- Trust chips -->
      <div class="mt-10 flex flex-wrap gap-2.5">
        {trustChips.map(({ icon, text }) => (
          <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.07] px-4 py-2 text-sm font-semibold text-white/75 backdrop-blur-sm">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-teal text-slate-900 text-[10px] font-bold">
              {icon}
            </span>
            {text}
          </div>
        ))}
      </div>
    </div>

    <!-- ── RIGHT: Photo panel (desktop only) ─────────────────────────────── -->
    <div class="relative hidden items-center justify-center py-20 pr-8 lg:flex xl:pr-12">

      <!-- Decorative concentric rings behind the photo -->
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <div class="h-[560px] w-[560px] rounded-full border border-teal/[0.15]"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <div class="h-[480px] w-[480px] rounded-full border border-gold/[0.10]"></div>
      </div>

      <!-- Photo card -->
      <div class="relative w-full max-w-[460px]">

        <!-- The photo — full brightness, no overlay -->
        <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={heroBg}
            alt="Professionally cleaned home interior in Fishers, Indiana — HC ServiClean"
            width={520}
            height={620}
            class="h-[520px] w-full object-cover object-center"
            fetchpriority="high"
            decoding="sync"
            loading="eager"
          />
        </div>

        <!-- Floating card: families served -->
        <div class="absolute -bottom-5 -left-8 flex items-center gap-3 rounded-2xl bg-white px-5 py-3.5 shadow-2xl">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal/10 text-xl">
            🏠
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Happy Families</p>
            <p class="text-xl font-bold text-slate-900">500+</p>
          </div>
        </div>

        <!-- Floating card: star rating -->
        <div class="absolute -top-5 -right-6 flex items-center gap-3 rounded-2xl bg-white px-5 py-3.5 shadow-2xl">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-xl">
            ⭐
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Client Rating</p>
            <p class="text-base font-bold text-slate-900">
              5.0 <span class="text-sm font-normal text-gold">★★★★★</span>
            </p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <button
    data-scroll-next
    aria-label="Scroll down to explore"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 transition-colors duration-200 hover:text-white/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white rounded"
  >
    <div class="flex h-9 w-5 items-start justify-center rounded-full border-2 border-current pt-1.5">
      <div class="h-2 w-px animate-bounce rounded-full bg-current"></div>
    </div>
    <span class="text-[9px] font-bold uppercase tracking-widest">Scroll</span>
  </button>

</section>

<script>
  document.querySelector('[data-scroll-next]')?.addEventListener('click', () => {
    document.querySelector('[data-hero]')
      ?.nextElementSibling
      ?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
