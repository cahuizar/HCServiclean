---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/family-living-room.png';
import BubbleDecor from '../shared/BubbleDecor.astro';
const yearsInBusiness = new Date().getFullYear() - 2010;
---

<section
  id="home"
  data-hero
  class="relative overflow-hidden bg-slate-900"
  aria-label="Hero"
>
  <BubbleDecor variant="dark" />

  <div class="relative z-10 grid w-full grid-cols-1 lg:grid-cols-2 lg:min-h-screen">

    <!-- ── LEFT: Copy panel ──────────────────────────────────────────────── -->
    <div class="flex flex-col items-center text-center justify-start pt-28 pb-12 px-[6vw] lg:items-start lg:text-left lg:justify-center lg:pl-[7vw] lg:pr-[4vw] lg:py-28">

      <h1 class="leading-tight text-white">
        <span class="block text-5xl font-bold sm:text-6xl lg:text-7xl xl:text-8xl">
          Spotless homes,<br />happy families.
        </span>
        <span class="mt-4 block text-base font-medium tracking-wide text-white/60 sm:text-lg xl:mt-6 xl:text-xl">
          Professional house cleaning across central Indiana
        </span>
      </h1>

      <p class="mt-5 max-w-md text-base leading-relaxed text-white/50 xl:max-w-lg xl:text-lg">
        Background-checked, full-time staff serving Fishers, Carmel, Noblesville,
        Indianapolis &amp; surrounding communities for over
        <strong class="font-semibold text-white/70">{yearsInBusiness} years</strong>.
        Satisfaction guaranteed on every clean.
      </p>

      <div class="mt-8">
        <a href="/estimate/" class="btn-primary text-base px-10 py-4">
          Get a Free Estimate
        </a>
      </div>

    </div>

    <!-- ── RIGHT: Photo panel ──────────────────────────────────────────────── -->
    <div class="flex flex-col items-center justify-center pb-20 px-[6vw] lg:py-20 lg:pr-[7vw] lg:pl-4">

      <!-- Decorative rings — desktop only -->
      <div class="pointer-events-none absolute inset-0 hidden lg:flex items-center justify-center" aria-hidden="true">
        <div class="h-[560px] w-[560px] rounded-full border border-teal/[0.15] xl:h-[640px] xl:w-[640px] 2xl:h-[760px] 2xl:w-[760px]"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 hidden lg:flex items-center justify-center" aria-hidden="true">
        <div class="h-[480px] w-[480px] rounded-full border border-gold/[0.10] xl:h-[560px] xl:w-[560px] 2xl:h-[660px] 2xl:w-[660px]"></div>
      </div>

      <!-- Photo card -->
      <div class="relative w-full max-w-[520px] overflow-visible xl:max-w-[600px]">

        <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={heroBg}
            alt="Professionally cleaned home interior in Fishers, Indiana — HC ServiClean"
            width={1200}
            quality={100}
            class="h-[340px] w-full object-cover object-left lg:object-[25%_50%] sm:h-[400px] lg:h-[520px] xl:h-[580px]"
            fetchpriority="high"
            decoding="sync"
            loading="eager"
          />
        </div>

        <!-- Client Rating card -->
        <div class="card-rating card-animate absolute top-3 right-3 flex items-center gap-2 rounded-2xl bg-white px-3 py-2.5 shadow-2xl sm:gap-3 sm:px-5 sm:py-3.5 lg:-top-5 lg:-right-6">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gold/10 text-base sm:h-10 sm:w-10 sm:text-xl">
            ⭐
          </div>
          <div>
            <p class="text-[10px] font-semibold text-slate-400 sm:text-xs">Client Rating</p>
            <p class="text-sm font-bold text-slate-900 sm:text-base">
              5.0 <span class="text-xs font-normal text-gold sm:text-sm">★★★★★</span>
            </p>
          </div>
        </div>

        <!-- Happy Families card -->
        <div class="card-families card-animate absolute bottom-3 left-3 flex items-center gap-2 rounded-2xl bg-white px-3 py-2.5 shadow-2xl sm:gap-3 sm:px-5 sm:py-3.5 lg:-bottom-5 lg:-left-8">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal/10 text-base sm:h-10 sm:w-10 sm:text-xl">
            🏠
          </div>
          <div>
            <p class="text-[10px] font-semibold text-slate-400 sm:text-xs">Happy Families</p>
            <p class="text-lg font-bold text-slate-900 sm:text-xl">500+</p>
          </div>
        </div>

      </div>
    </div>

  </div>

</section>

<style>
  /* ─────────────────────────────────────────────────────────────
     CARD ENTRANCE ANIMATION — tweak these to adjust timing/feel
     All values are plain numbers (ms or unitless) so JS can read them.
     ───────────────────────────────────────────────────────────── */
  :root {
    /* How long (ms) before the rating card starts appearing */
    --card-rating-delay:   1000;

    /* Fade + grow duration (ms) for each card */
    --card-fade-duration:   2000;

    /* Starting scale — cards grow from this to 1.0 */
    --card-scale-from:     0.5;

    /* Extra pause (ms) between rating finishing and families starting */
    --card-families-gap:    1000;
  }

  /* Rating card: arrow points down into the image */
  .card-rating::after {
    content: '';
    position: absolute;
    bottom: -7px;
    left: 18px;
    width: 0;
    height: 0;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-top: 7px solid white;
  }

  /* Families card: arrow points up into the image */
  .card-families::after {
    content: '';
    position: absolute;
    top: -7px;
    right: 18px;
    width: 0;
    height: 0;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-bottom: 7px solid white;
  }
</style>

<script>
  document.querySelector('[data-scroll-next]')?.addEventListener('click', () => {
    document.querySelector('[data-hero]')
      ?.nextElementSibling
      ?.scrollIntoView({ behavior: 'smooth' });
  });

  // ── Hero card entrance animation ────────────────────────────────
  // Edit timing in the CSS :root block above — no JS changes needed.
  (function () {
    const rootStyle = getComputedStyle(document.documentElement);
    const get = (name: string, fallback: number) =>
      parseFloat(rootStyle.getPropertyValue(name).trim()) || fallback;

    const ratingDelay  = get('--card-rating-delay',  1000);
    const fadeDuration = get('--card-fade-duration',  700);
    const scaleFrom    = get('--card-scale-from',     0.82);
    const familiesGap  = get('--card-families-gap',   200);

    const cardRating   = document.querySelector<HTMLElement>('.card-rating');
    const cardFamilies = document.querySelector<HTMLElement>('.card-families');
    if (!cardRating || !cardFamilies) return;

    // The easing gives a gentle overshoot/pop on the scale.
    const easing = 'cubic-bezier(0.34, 1.3, 0.64, 1)';

    // Helper: animate a card from hidden/small → visible/full-size.
    // Strategy: set initial inline state → wait for delay → set transition →
    // requestAnimationFrame → apply final state.
    // The rAF guarantees the browser has painted the initial state before we
    // change it, so the transition always fires (no batching/skipping).
    // setImportant overrides Tailwind's `transition-duration: 0.01ms !important`
    // that fires when the OS has "reduce motion" enabled — we intentionally
    // keep our entrance animation even in that mode.
    function setImportant(card: HTMLElement, prop: string, value: string) {
      card.style.setProperty(prop, value, 'important');
    }

    function animateCard(card: HTMLElement, delay: number) {
      // 1. Lock initial state
      setImportant(card, 'opacity', '0');
      setImportant(card, 'transform', `scale(${scaleFrom})`);

      setTimeout(() => {
        // 2. Set transition with !important so it beats the reduced-motion override
        setImportant(card, 'transition',
          `opacity ${fadeDuration}ms ease-out, transform ${fadeDuration}ms ${easing}`);

        // 3. rAF ensures the browser has painted the initial state before we
        //    change it — without this the transition can get skipped entirely
        requestAnimationFrame(() => {
          setImportant(card, 'opacity', '1');
          setImportant(card, 'transform', 'scale(1)');
        });
      }, delay);
    }

    animateCard(cardRating,   ratingDelay);
    animateCard(cardFamilies, ratingDelay + fadeDuration + familiesGap);
  })();
</script>
