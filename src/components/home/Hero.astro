---
import { Image } from 'astro:assets';
import heroBg from '../../assets/images/carousel-1.jpg';
import BubbleDecor from '../shared/BubbleDecor.astro';
const yearsInBusiness = new Date().getFullYear() - 2010;
---

<section
  id="home"
  data-hero
  class="relative overflow-hidden bg-slate-900"
  aria-label="Hero"
>
  <BubbleDecor variant="dark" />

  <!-- Two-column grid: copy left, photo right -->
  <div class="relative z-10 mx-auto grid min-h-screen max-w-7xl grid-cols-1 lg:grid-cols-2">

    <!-- ── LEFT: Copy panel ──────────────────────────────────────────────── -->
    <div class="flex flex-col justify-center px-6 py-36 sm:px-12 lg:px-16 lg:py-28">

      <!-- Eyebrow: brand name (small, not the hero) -->
      <p class="mb-4 text-sm font-bold uppercase tracking-widest text-teal">
        HC ServiClean
      </p>

      <!-- H1: punchy hook + keyword location anchor -->
      <h1 class="leading-tight text-white">
        <span class="block text-5xl font-bold sm:text-6xl lg:text-7xl">
          Spotless homes,<br />happy families.
        </span>
        <span class="mt-4 block text-base font-medium tracking-wide text-white/60 sm:text-lg">
          Professional house cleaning — Fishers, Carmel &amp; Indianapolis, IN
        </span>
      </h1>

      <!-- Supporting copy -->
      <p class="mt-5 max-w-sm text-base leading-relaxed text-white/50">
        Background-checked, full-time staff serving central Indiana for over
        <strong class="font-semibold text-white/70">{yearsInBusiness} years</strong>.
        Satisfaction guaranteed on every clean.
      </p>

      <!-- Single strong CTA -->
      <div class="mt-8">
        <a href="/estimate/" class="btn-primary text-base px-10 py-4">
          Get a Free Estimate
        </a>
      </div>

    </div>

    <!-- ── RIGHT: Photo panel (desktop only) ─────────────────────────────── -->
    <div class="relative hidden items-center justify-center py-20 pr-8 lg:flex xl:pr-12">

      <!-- Decorative concentric rings behind the photo -->
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <div class="h-[560px] w-[560px] rounded-full border border-teal/[0.15]"></div>
      </div>
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
        <div class="h-[480px] w-[480px] rounded-full border border-gold/[0.10]"></div>
      </div>

      <!-- Photo card -->
      <div class="relative w-full max-w-[460px]">

        <!-- The photo — full brightness, no overlay -->
        <div class="overflow-hidden rounded-3xl shadow-2xl ring-1 ring-white/10">
          <Image
            src={heroBg}
            alt="Professionally cleaned home interior in Fishers, Indiana — HC ServiClean"
            width={520}
            height={620}
            class="h-[520px] w-full object-cover object-center"
            fetchpriority="high"
            decoding="sync"
            loading="eager"
          />
        </div>

        <!-- Floating card: families served -->
        <div class="absolute -bottom-5 -left-8 flex items-center gap-3 rounded-2xl bg-white px-5 py-3.5 shadow-2xl">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal/10 text-xl">
            🏠
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Happy Families</p>
            <p class="text-xl font-bold text-slate-900">500+</p>
          </div>
        </div>

        <!-- Floating card: star rating -->
        <div class="absolute -top-5 -right-6 flex items-center gap-3 rounded-2xl bg-white px-5 py-3.5 shadow-2xl">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold/10 text-xl">
            ⭐
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-400">Client Rating</p>
            <p class="text-base font-bold text-slate-900">
              5.0 <span class="text-sm font-normal text-gold">★★★★★</span>
            </p>
          </div>
        </div>

      </div>
    </div>

  </div>

</section>

<script>
  // Keep the scroll-next behavior if other components use it
  document.querySelector('[data-scroll-next]')?.addEventListener('click', () => {
    document.querySelector('[data-hero]')
      ?.nextElementSibling
      ?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
