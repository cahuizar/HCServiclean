---
import { testimonials } from '../../data/testimonials';
---

<section class="bg-slate-50 py-20" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">

    <div class="mb-14 text-center">
      <p class="mb-3 text-xs font-bold uppercase tracking-widest text-teal">Happy Clients</p>
      <h2 id="testimonials-heading" class="text-3xl font-bold text-slate-900 sm:text-4xl">
        What Our Clients Say
      </h2>
      <p class="mx-auto mt-3 max-w-lg text-slate-500">
        Don't just take our word for it — hear from families we've served across Indiana.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="flex flex-col rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-md">

          <!-- Large decorative quote mark -->
          <div class="mb-4 text-5xl font-bold leading-none text-teal/20 select-none" aria-hidden="true">"</div>

          <!-- Stars -->
          <div class="mb-4 flex gap-1" aria-label="5 out of 5 stars" role="img">
            {Array(5).fill(null).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-gold" aria-hidden="true">
                <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="flex-1">
            <p class="text-sm leading-relaxed text-slate-600">{t.quote}</p>
          </blockquote>

          <!-- Author -->
          <figcaption class="mt-6 flex items-center gap-4 border-t border-slate-100 pt-5">
            <div
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-teal text-slate-900 text-sm font-bold"
              aria-hidden="true"
            >
              {t.author.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <p class="font-bold text-slate-900">{t.author}</p>
              <p class="text-xs text-slate-400">{t.city}, Indiana · Verified Client</p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
