---
import { testimonials } from '../../data/testimonials';
import SectionHeader from '../shared/SectionHeader.astro';
---

<section class="bg-teal-50 py-20" aria-labelledby="testimonials-heading">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      id="testimonials-heading"
      title="What Our Clients Say"
      subtitle="Don't just take our word for it — hear from our happy customers across the Indianapolis area."
      centered
    />

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col rounded-2xl border border-teal-light bg-white p-6 shadow-sm">
            <!-- Stars -->
            <div class="mb-4 flex gap-1" aria-label="5 stars" role="img">
              {Array(5).fill(null).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-gold" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
                </svg>
              ))}
            </div>

            <blockquote class="flex-1">
              <p class="text-sm leading-relaxed text-slate-600">"{t.quote}"</p>
            </blockquote>

            <figcaption class="mt-5 flex items-center gap-3 border-t border-slate-100 pt-4">
              <!-- Avatar placeholder with initials -->
              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal text-slate-900 text-sm font-bold"
                aria-hidden="true"
              >
                {t.author.split(' ').map((n: string) => n[0]).join('')}
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900">{t.author}</p>
                <p class="text-xs text-slate-500">{t.city}, Indiana</p>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
