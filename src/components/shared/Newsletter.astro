---
---

<section class="bg-white border-t border-slate-100 py-20" aria-labelledby="newsletter-heading">
  <div class="mx-auto max-w-xl px-4 text-center sm:px-6">

    <!-- Icon -->
    <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-100">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-7 w-7 text-teal"
        aria-hidden="true"
      >
        <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
        <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
      </svg>
    </div>

    <!-- Heading -->
    <h2 id="newsletter-heading" class="text-2xl font-bold text-slate-900 sm:text-3xl">
      Stay in the Loop
    </h2>
    <p class="mt-2 text-slate-500">
      Get exclusive deals and cleaning tips delivered to your inbox. No spam, ever.
    </p>

    <!-- Form -->
    <form
      action="https://formsubmit.co/18b17300afc0862f33349630a5af1370"
      method="post"
      class="mt-6 flex flex-col gap-3 sm:flex-row"
      aria-label="Newsletter signup"
    >
      <input type="hidden" name="_subject" value="Add User To Newsletter Request" />
      <input
        type="hidden"
        name="_autoresponse"
        value="Thank you, you have been added to the newsletter list. For any questions you can email us at: contact@hcserviclean.com"
      />
      <input type="hidden" name="_template" value="table" />

      <div class="flex-1">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          id="newsletter-email"
          name="email"
          type="email"
          required
          placeholder="Your email address"
          autocomplete="email"
          class="w-full min-h-[44px] rounded-full border border-slate-200 bg-slate-50 px-5 py-2.5 text-slate-900 placeholder-slate-400 transition focus:border-teal focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal/30"
        />
      </div>

      <button
        type="submit"
        class="btn-primary whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>

    <p class="mt-3 text-xs text-slate-400">
      We respect your privacy. Unsubscribe anytime.
    </p>
  </div>
</section>
