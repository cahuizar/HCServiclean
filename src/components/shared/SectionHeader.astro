---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
  id?: string;
}

const { title, subtitle, centered = false, light = false, id } = Astro.props;
---

<div class:list={['mb-10', centered && 'text-center']}>
  <h2
    id={id}
    class:list={[
      'text-3xl font-bold tracking-tight sm:text-4xl',
      light ? 'text-white' : 'text-slate-900',
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={[
          'mt-3 max-w-2xl text-lg leading-relaxed',
          centered && 'mx-auto',
          light ? 'text-white/80' : 'text-slate-600',
        ]}
      >
        {subtitle}
      </p>
    )
  }
  <div
    class:list={[
      'mt-4 h-1 w-16 rounded-full bg-gold',
      centered && 'mx-auto',
    ]}
  >
  </div>
</div>
