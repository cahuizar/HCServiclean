---
interface Props {
  question: string;
  answer: string;
}
const { question, answer } = Astro.props;
---

<details class="group border-b border-slate-200 last:border-b-0">
  <summary
    class="flex cursor-pointer items-center justify-between gap-4 py-4 text-left text-base font-bold text-slate-900 transition-colors hover:text-teal-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal focus-visible:ring-inset list-none"
  >
    <span>{question}</span>
    <!-- Plus / minus indicator -->
    <span
      class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-teal-50 text-teal transition-all duration-200 group-open:rotate-45 group-open:bg-teal group-open:text-slate-900"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M12 3.75a.75.75 0 01.75.75v6.75h6.75a.75.75 0 010 1.5h-6.75v6.75a.75.75 0 01-1.5 0v-6.75H4.5a.75.75 0 010-1.5h6.75V4.5a.75.75 0 01.75-.75z" clip-rule="evenodd"/>
      </svg>
    </span>
  </summary>

  <div class="pb-5 pr-10 text-sm leading-relaxed text-slate-600" set:html={answer} />
</details>
