---
interface Props {
  yearsInBusiness: number;
}
const { yearsInBusiness } = Astro.props;
const currentYear = new Date().getFullYear();

const pageLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/faq', label: 'FAQ' },
  { href: '/estimate', label: 'Free Estimate' },
];
---

<footer class="bg-slate-900 text-slate-300">
  <!-- Brand accent bar -->
  <div class="h-1 w-full bg-gradient-to-r from-teal via-gold to-teal"></div>
  <div class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal rounded">
          <img
            src="/images/logo-no-slogan.svg"
            alt="HC ServiClean LLC logo"
            width="608"
            height="509"
            class="h-16 w-auto brightness-0 invert"
            loading="lazy"
          />
        </a>
        <p class="mt-3 text-sm leading-relaxed text-slate-400">
          The cleaning solution to all of your needs.<br />
          Serving Indiana since 2010 — over {yearsInBusiness} years of excellence.
        </p>
        <!-- Social links -->
        <div class="mt-4 flex gap-4">
          <a
            href="https://www.facebook.com/profile.php?id=61555496861439"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="HC ServiClean on Facebook"
            class="flex h-11 w-11 items-center justify-center rounded-full bg-slate-800 text-slate-300 transition-colors hover:bg-gold hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
          >
            <!-- Facebook icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://www.yelp.com/biz/hc-serviclean-noblesville-2"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="HC ServiClean on Yelp"
            class="flex h-11 w-11 items-center justify-center rounded-full bg-slate-800 text-slate-300 transition-colors hover:bg-gold hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
          >
            <!-- Yelp icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M20.16 12.73l-4.916 1.135c-.83.19-1.572-.584-1.31-1.398l.055-.17 1.694-4.689c.297-.82 1.38-.98 1.898-.27l3.223 4.386c.47.64.07 1.54-.644 1.706zM10.78 20.01l.433-5.025c.073-.847.975-1.3 1.69-.857l.155.1 4.204 3.147c.733.548.59 1.666-.243 2.016l-4.637 1.878c-.787.32-1.658-.274-1.602-1.26zm-7.857-1.024l4.37-2.583c.739-.437 1.608.056 1.624.914v.181l-.082 5.075c-.014.858-.914 1.381-1.672.982L2.718 21.29c-.743-.385-.855-1.41-.195-1.953zm3.093-7.938c.543-.662 1.582-.567 1.99.18l.085.17 2.24 4.576c.378.772-.14 1.664-1 1.68h-.182L4.024 17.6c-.866-.016-1.42-.915-1.073-1.706l2.065-4.846zm5.025-8.06l.092 5.075c.016.856-.846 1.412-1.602.994l-.157-.095L4.97 6.018c-.74-.513-.644-1.64.166-2.02L9.73 1.906c.804-.38 1.703.2 1.71 1.082z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Page Links -->
      <div>
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-gold">
          Quick Links
        </h2>
        <ul class="space-y-2" role="list">
          {
            pageLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-400 transition-colors hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold rounded"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-gold">
          Contact Us
        </h2>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href="mailto:contact@hcserviclean.com?Subject=Question"
              class="flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold rounded"
            >
              <!-- Email icon -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0 text-gold" aria-hidden="true">
                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
              </svg>
              contact@hcserviclean.com
            </a>
          </li>
          <li>
            <a
              href="tel:+18472934525"
              class="flex items-center gap-2 text-sm text-slate-400 transition-colors hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold rounded"
            >
              <!-- Phone icon -->
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0 text-gold" aria-hidden="true">
                <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd"/>
              </svg>
              (847) 293-4525
            </a>
          </li>
          <li class="flex items-start gap-2 text-sm text-slate-400">
            <!-- Clock icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="mt-0.5 h-4 w-4 shrink-0 text-teal" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/>
            </svg>
            <span>Mon–Sat: 8:00 AM – 5:00 PM</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-slate-700 pt-6 text-center text-xs text-slate-500">
      <p>
        &copy; {currentYear} HC ServiClean LLC. All rights reserved.
      </p>
    </div>
  </div>
</footer>
