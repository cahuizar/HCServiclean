---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from '../assets/images/logo-no-slogan.png';
interface Props {
  yearsInBusiness: number;
}
const { yearsInBusiness } = Astro.props;
const currentYear = new Date().getFullYear();

const pageLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/services/', label: 'Services' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/estimate/', label: 'Free Estimate' },
];
---

<footer class="relative overflow-hidden bg-white" aria-label="Site footer">

  <!-- Decorative bubble shapes -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -bottom-28 -left-28 h-96 w-96 rounded-full bg-teal opacity-[0.07]"></div>
    <div class="absolute -top-20 -right-20 h-72 w-72 rounded-full bg-gold opacity-[0.09]"></div>
    <div class="absolute bottom-10 right-[20%] h-48 w-48 rounded-full border-2 border-teal opacity-[0.08]"></div>
    <div class="absolute top-1/2 left-[40%] h-32 w-32 rounded-full bg-teal opacity-[0.05]"></div>
    <div class="absolute top-8 left-[15%] h-20 w-20 rounded-full border border-gold opacity-[0.10]"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">

      <!-- Brand -->
      <div>
        <a href="/" aria-label="HC ServiClean — go to homepage" class="inline-block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal rounded">
          <Image
            src={logo}
            alt="HC ServiClean LLC logo"
            class="h-16 w-auto"
            loading="lazy"
          />
        </a>
        <p class="mt-3 text-sm leading-relaxed text-slate-500">
          The cleaning solution to all of your needs.<br />
          Serving Indiana since 2010 — over {yearsInBusiness} years of excellence.
        </p>

        <!-- Social links -->
        <div class="mt-4 flex gap-3">
          <a
            href="https://www.facebook.com/profile.php?id=61555496861439"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="HC ServiClean on Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 text-teal transition-colors hover:bg-teal hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal"
          >
            <Icon name="fa6-brands:facebook" class="h-5 w-5" aria-hidden="true" />
          </a>
          <a
            href="https://www.yelp.com/biz/hc-serviclean-noblesville-2"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="HC ServiClean on Yelp"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-50 text-teal transition-colors hover:bg-teal hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal"
          >
            <Icon name="fa6-brands:yelp" class="h-5 w-5" aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-teal">
          Quick Links
        </h2>
        <ul class="space-y-2" role="list">
          {pageLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-500 transition-colors hover:text-teal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal rounded"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-teal">
          Contact Us
        </h2>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href="mailto:info@hcserviclean.com"
              class="flex items-center gap-2 text-sm text-slate-500 transition-colors hover:text-teal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal rounded"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0 text-teal" aria-hidden="true">
                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
              </svg>
              info@hcserviclean.com
            </a>
          </li>
          <li>
            <a
              href="tel:+18472934525"
              class="flex items-center gap-2 text-sm text-slate-500 transition-colors hover:text-teal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal rounded"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0 text-teal" aria-hidden="true">
                <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd"/>
              </svg>
              (847) 293-4525
            </a>
          </li>
          <li class="flex items-start gap-2 text-sm text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="mt-0.5 h-4 w-4 shrink-0 text-teal" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/>
            </svg>
            <span>Mon–Sat: 8:00 AM – 5:00 PM</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-slate-100 pt-6 text-center text-xs text-slate-400">
      <p>&copy; {currentYear} HC ServiClean LLC. All rights reserved.</p>
    </div>
  </div>

  <!-- Subtle bottom gradient -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-teal-50/30 to-transparent" aria-hidden="true"></div>
</footer>
