---
import { Image } from 'astro:assets';
import type { ServiceItem } from '../../data/services';

interface Props {
  service: ServiceItem;
  loading?: 'lazy' | 'eager';
}
const { service, loading = 'lazy' } = Astro.props;
---

<article class="group overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
  <div class="aspect-[4/3] overflow-hidden">
    <Image
      src={service.image}
      alt={service.imageAlt}
      width={600}
      height={450}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading={loading}
    />
  </div>

  <div class="p-6">
    <div class="mb-4 flex items-center gap-3">
      <div class="h-1 w-8 rounded-full bg-teal"></div>
      <h3 class="text-xl font-bold text-slate-900">{service.title}</h3>
    </div>

    <ul class="space-y-2" role="list">
      {
        service.items.map((item) => (
          <li class="flex items-start gap-3 text-sm text-slate-600">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="mt-0.5 h-4 w-4 shrink-0 text-teal"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                clip-rule="evenodd"
              />
            </svg>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</article>
